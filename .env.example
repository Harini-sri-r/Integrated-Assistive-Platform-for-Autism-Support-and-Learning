# Copy this file to .env and fill in values. Never commit .env.

# Required for any shared or deployed build (generate a long random string)
# SECRET_KEY=replace-with-a-long-random-string

# Default: SQLite in instance/platform_v3.db
# DATABASE_URL=sqlite:///C:/path/to/instance/platform_v3.db

# Optional: enables Gemini in the chatbot (rule-based mode works without it)
# GEMINI_API_KEY=

# Local dev: set to false to turn off Flask debug
# FLASK_DEBUG=true
